{
  "name": "Silero VAD Pipeline",
  "version": "1.0",
  "log_level": "info",
  "global": {
    "properties": {
      "model_root": "model/vad"
    }
  },
  "frame": {
    "sample_rate": 16000,
    "channels": 1,
    "dur_ms": 10
  },
  "stream": {
    "ring_capacity_frames": 6000
  },
  "pipelines": [
    {
      "id": "vad_stage",
      "name": "VAD Detection Stage",
      "max_concurrency": 4,
      "input": {
        "key": "audio_frames",
        "chunk_size": 1600
      },
      "ops": [
        {
          "id": "silero_vad",
          "name": "SileroVad",
          "params": {
            "model_path": "${model_root}/silero_vad.onnx",
            "threshold": 0.5,
            "sample_rate": 16000,
            "input_frame_key": "audio_frames",
            "min_speech_duration_ms": 250,
            "min_silence_duration_ms": 100
          }
        }
      ]
    }
  ]
}
