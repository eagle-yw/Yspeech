{
  "name": "Offline Paraformer ASR",
  "version": "1.0",
  "task": "asr",
  "mode": "offline",
  "frame": {
    "sample_rate": 16000,
    "channels": 1,
    "dur_ms": 10
  },
  "pipelines": [
    {
      "id": "source_stage",
      "name": "Source Stage",
      "ops": [
        {
          "id": "source",
          "name": "FileSource",
          "params": {
            "path": "__AUDIO_PATH__"
          }
        }
      ]
    },
    {
      "id": "asr_stage",
      "name": "ASR Recognition Stage",
      "depends_on": ["source_stage"],
      "max_concurrency": 1,
      "input": {
        "key": "audio_frames",
        "chunk_size": 1600
      },
      "ops": [
        {
          "id": "fbank",
          "name": "KaldiFbank",
          "params": {
            "num_bins": 80,
            "sample_rate": 16000,
            "frame_length_ms": 25,
            "frame_shift_ms": 10,
            "dither": 0,
            "snip_edges": false,
            "window_type": "hamming",
            "input_frame_key": "audio_frames",
            "output_key": "fbank",
            "lfr_window_size": 7,
            "lfr_window_shift": 6,
            "cmvn_file": "model/asr/sherpa-onnx-paraformer-zh-2023-09-14/am.mvn"
          }
        },
        {
          "id": "paraformer_asr",
          "name": "AsrParaformer",
          "params": {
            "model_path": "model/asr/sherpa-onnx-paraformer-zh-2023-09-14/model.int8.onnx",
            "tokens_path": "model/asr/sherpa-onnx-paraformer-zh-2023-09-14/tokens.txt",
            "feature_input_key": "fbank",
            "language": "zh"
          },
          "depends_on": ["fbank"]
        }
      ]
    }
  ]
}
