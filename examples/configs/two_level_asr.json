{
  "name": "Two-Level Paraformer ASR Template",
  "version": "1.0",
  "task": "asr",
  "mode": "streaming",
  "log_level": "info",
  "runtime": {
    "pipeline_lines": 4,
    "pipeline_name": "yspeech.streaming.two_level",
    "asr_core_pool_size": 4
  },
  "global": {
    "properties": {
      "model_root": "model/asr/sherpa-onnx-paraformer-zh-2023-09-14",
      "vad_model": "model/vad/silero_vad.onnx"
    }
  },
  "frame": {
    "sample_rate": 16000,
    "channels": 1,
    "dur_ms": 10
  },
  "stream": {
    "ring_capacity_frames": 6000
  },
  "pipelines": [
    {
      "id": "source_stage",
      "name": "Source Stage",
      "ops": [
        {
          "id": "source",
          "name": "FileSource",
          "params": {
            "path": "__AUDIO_PATH__",
            "playback_rate": 20.0
          }
        }
      ]
    },
    {
      "id": "vad_stage",
      "name": "VAD Stage",
      "depends_on": ["source_stage"],
      "max_concurrency": 4,
      "input": {
        "key": "audio_frames",
        "chunk_size": 1600
      },
      "ops": [
        {
          "id": "silero_vad",
          "name": "SileroVad",
          "params": {
            "model_path": "${vad_model}",
            "threshold": 0.5,
            "sample_rate": 16000,
            "input_frame_key": "audio_frames",
            "min_speech_duration_ms": 250,
            "min_silence_duration_ms": 100
          }
        }
      ]
    },
    {
      "id": "asr_stage",
      "name": "ASR Stage",
      "depends_on": ["source_stage"],
      "max_concurrency": 4,
      "input": {
        "key": "audio_frames"
      },
      "ops": [
        {
          "id": "fbank",
          "name": "KaldiFbank",
          "params": {
            "num_bins": 80,
            "sample_rate": 16000,
            "frame_length_ms": 25,
            "frame_shift_ms": 10,
            "dither": 0,
            "snip_edges": false,
            "input_frame_key": "audio_frames",
            "output_key": "fbank",
            "lfr_window_size": 7,
            "lfr_window_shift": 6,
            "cmvn_file": "${model_root}/am.mvn",
            "enable_accumulation": true,
            "min_accumulated_frames": 15,
            "max_accumulated_frames": 100
          }
        },
        {
          "id": "paraformer_asr",
          "name": "AsrParaformer",
          "params": {
            "model_path": "${model_root}/model.int8.onnx",
            "tokens_path": "${model_root}/tokens.txt",
            "feature_input_key": "fbank",
            "sample_rate": 16000,
            "language": "zh",
            "execution_provider": "cpu",
            "num_threads": 2,
            "min_new_feature_frames": 12
          },
          "depends_on": ["fbank"]
        }
      ]
    }
  ]
}
