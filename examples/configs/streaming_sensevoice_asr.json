{
  "name": "Streaming SenseVoice ASR",
  "version": "1.0",
  "log_level": "info",
  "task": "asr",
  "mode": "streaming",
  "runtime": {
    "pipeline_lines": 2,
    "pipeline_name": "yspeech.taskflow.streaming",
    "asr_core_pool_size": 2
  },
  "frame": {
    "sample_rate": 16000,
    "channels": 1,
    "dur_ms": 10
  },
  "stream": {
    "ring_capacity_frames": 4096
  },
  "pipelines": [
    {
      "id": "source_stage",
      "name": "Source Stage",
      "ops": [
        {
          "id": "source",
          "name": "FileSource",
          "params": {
            "path": "__AUDIO_PATH__",
            "playback_rate": 0.0
          }
        }
      ]
    },
    {
      "id": "vad_stage",
      "name": "VAD Stage",
      "depends_on": ["source_stage"],
      "max_concurrency": 1,
      "ops": [
        {
          "id": "vad",
          "name": "SileroVad",
          "params": {
            "model_path": "model/vad/silero_vad.onnx",
            "sample_rate": 16000,
            "min_speech_duration_ms": 250,
            "min_silence_duration_ms": 100
          }
        }
      ]
    },
    {
      "id": "feature_stage",
      "name": "Feature Stage",
      "depends_on": ["vad_stage"],
      "max_concurrency": 2,
      "ops": [
        {
          "id": "fbank",
          "name": "KaldiFbank",
          "params": {
            "sample_rate": 16000,
            "num_bins": 80,
            "frame_length_ms": 25,
            "frame_shift_ms": 10,
            "dither": 0,
            "snip_edges": false,
            "lfr_window_size": 7,
            "lfr_window_shift": 7
          }
        }
      ]
    },
    {
      "id": "asr_stage",
      "name": "ASR Stage",
      "depends_on": ["feature_stage"],
      "max_concurrency": 2,
      "ops": [
        {
          "id": "asr",
          "name": "AsrSenseVoice",
          "params": {
            "model_path": "model/asr/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-2024-07-17/model.onnx",
            "tokens_path": "model/asr/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-2024-07-17/tokens.txt",
            "language": "auto",
            "use_itn": true,
            "detect_emotion": true,
            "sample_rate": 16000,
            "execution_provider": "cpu",
            "num_threads": 4
          }
        }
      ]
    }
  ]
}
