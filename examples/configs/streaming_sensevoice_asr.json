{
  "name": "SenseVoice ASR",
  "version": "1.0",
  "log_level": "info",
  "mode": "streaming",
  "source": {
    "type": "file"
  },
  "frame": {
    "sample_rate": 16000,
    "channels": 1,
    "dur_ms": 10
  },
  "stream": {
    "ring_capacity_frames": 6000
  },
  "pipeline": {
    "push_chunk_samples": 1600
  },
  "output": {
    "type": "callback",
    "include_segments": true,
    "include_timestamp": true
  },
  "pipelines": [
    {
      "id": "vad_stage",
      "name": "VAD Detection Stage",
      "max_concurrency": 4,
      "input": {
        "key": "audio_buffer",
        "chunk_size": 1600
      },
      "output": {
        "key": "vad_results"
      },
      "ops": [
        {
          "id": "silero_vad",
          "name": "SileroVad",
          "params": {
            "model_path": "model/vad/silero_vad.onnx",
            "threshold": 0.5,
            "sample_rate": 16000,
            "input_frame_key": "audio_frames",
            "min_speech_duration_ms": 250,
            "min_silence_duration_ms": 100
          }
        }
      ]
    },
    {
      "id": "asr_stage",
      "name": "SenseVoice Recognition Stage",
      "max_concurrency": 4,
      "input": {
        "key": "vad_results"
      },
      "output": {
        "key": "asr_results"
      },
      "ops": [
        {
          "id": "fbank",
          "name": "KaldiFbank",
          "params": {
            "num_bins": 80,
            "sample_rate": 16000,
            "frame_length_ms": 25,
            "frame_shift_ms": 10,
            "dither": 0,
            "snip_edges": false,
            "input_frame_key": "audio_frames",
            "output_key": "fbank",
            "lfr_window_size": 7,
            "lfr_window_shift": 7,
            "enable_accumulation": true,
            "min_accumulated_frames": 15,
            "max_accumulated_frames": 100
          }
        },
        {
          "id": "sensevoice_asr",
          "name": "AsrSenseVoice",
          "params": {
            "model_path": "model/asr/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-2024-07-17/model.onnx",
            "tokens_path": "model/asr/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-2024-07-17/tokens.txt",
            "feature_input_key": "fbank",
            "language": "auto",
            "use_itn": true,
            "detect_emotion": true,
            "sample_rate": 16000,
            "execution_provider": "cpu",
            "num_threads": 4
          },
          "depends_on": ["fbank"]
        }
      ]
    }
  ]
}
