{
  "name": "SenseVoice ASR",
  "version": "1.0",
  "mode": "offline",
  "source": {
    "type": "file",
    "path": "model/asr/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-2024-07-17/test_wavs/zh.wav"
  },
  "frame": {
    "sample_rate": 16000,
    "channels": 1,
    "dur_ms": 10
  },
  "pipeline": {
    "push_chunk_samples": -1
  },
  "output": {
    "type": "text",
    "include_segments": true,
    "include_timestamp": true
  },
  "pipelines": [
    {
      "id": "asr_stage",
      "name": "SenseVoice Recognition Stage",
      "max_concurrency": 1,
      "input": {
        "key": "audio_buffer",
        "chunk_size": -1
      },
      "output": {
        "key": "asr_results"
      },
      "ops": [
        {
          "id": "fbank",
          "name": "KaldiFbank",
          "params": {
            "num_bins": 80,
            "sample_rate": 16000,
            "frame_length_ms": 25,
            "frame_shift_ms": 10,
            "dither": 0,
            "snip_edges": false,
            "window_type": "hamming",
            "input_frame_key": "audio_frames",
            "output_key": "fbank",
            "lfr_window_size": 7,
            "lfr_window_shift": 7
          }
        },
        {
          "id": "sensevoice_asr",
          "name": "AsrSenseVoice",
          "params": {
            "model_path": "model/asr/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-2024-07-17/model.onnx",
            "tokens_path": "model/asr/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-2024-07-17/tokens.txt",
            "feature_input_key": "fbank",
            "language": "auto",
            "use_itn": true,
            "detect_emotion": true
          },
          "depends_on": ["fbank"]
        }
      ]
    }
  ]
}
