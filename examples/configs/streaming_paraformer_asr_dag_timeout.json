{
  "name": "Streaming Paraformer ASR DAG Timeout",
  "version": "1.0",
  "log_level": "info",
  "task": "asr",
  "mode": "streaming",
  "runtime": {
    "pipeline_lines": 2,
    "pipeline_name": "yspeech.streaming.dag.timeout"
  },
  "source": {
    "type": "file",
    "path": "model/asr/sherpa-onnx-paraformer-zh-2023-09-14/test_wavs/0.wav",
    "playback_rate": 0.0
  },
  "frame": {
    "sample_rate": 16000,
    "channels": 1,
    "dur_ms": 10
  },
  "stream": {
    "ring_capacity_frames": 4096
  },
  "pipelines": [
    {
      "id": "source_stage",
      "name": "Source Stage",
      "ops": [
        {
          "id": "source",
          "name": "FileSource"
        }
      ]
    },
    {
      "id": "vad_stage",
      "name": "VAD Stage",
      "depends_on": ["source_stage"],
      "max_concurrency": 1,
      "ops": [
        {
          "id": "vad",
          "name": "SileroVad",
          "params": {
            "model_path": "model/vad/silero_vad.onnx",
            "sample_rate": 16000,
            "min_speech_duration_ms": 250,
            "min_silence_duration_ms": 100
          }
        }
      ]
    },
    {
      "id": "feature_stage",
      "name": "Feature Stage",
      "depends_on": ["vad_stage"],
      "max_concurrency": 2,
      "ops": [
        {
          "id": "fbank",
          "name": "KaldiFbank",
          "params": {
            "sample_rate": 16000,
            "num_bins": 80,
            "frame_length_ms": 25,
            "frame_shift_ms": 10,
            "dither": 0,
            "snip_edges": false,
            "lfr_window_size": 7,
            "lfr_window_shift": 6,
            "cmvn_file": "model/asr/sherpa-onnx-paraformer-zh-2023-09-14/am.mvn"
          }
        }
      ]
    },
    {
      "id": "merge_stage",
      "name": "Merge Stage",
      "depends_on": ["vad_stage", "feature_stage"],
      "join_policy": "all_of",
      "join_timeout_ms": 0,
      "ops": [
        {
          "id": "merge",
          "name": "JoinBarrier"
        }
      ]
    },
    {
      "id": "asr_stage",
      "name": "ASR Stage",
      "depends_on": ["merge_stage"],
      "max_concurrency": 2,
      "ops": [
        {
          "id": "asr",
          "name": "AsrParaformer",
          "params": {
            "model_path": "model/asr/sherpa-onnx-paraformer-zh-2023-09-14/model.int8.onnx",
            "tokens_path": "model/asr/sherpa-onnx-paraformer-zh-2023-09-14/tokens.txt",
            "language": "zh",
            "num_threads": 2,
            "min_new_feature_frames": 24,
            "min_first_partial_feature_frames": 12
          }
        }
      ]
    }
  ]
}
