{
  "name": "Silero VAD Only",
  "version": "1.0",
  "task": "vad",
  "mode": "streaming",
  "log_level": "info",
  "global": {
    "properties": {
      "vad_model": "model/vad/silero_vad.onnx"
    }
  },
  "source": {
    "type": "microphone"
  },
  "frame": {
    "sample_rate": 16000,
    "channels": 1,
    "dur_ms": 10
  },
  "stream": {
    "ring_capacity_frames": 6000
  },
  "pipelines": [
    {
      "id": "source_stage",
      "name": "Source Stage",
      "ops": [
        {
          "id": "source",
          "name": "MicrophoneSource"
        }
      ]
    },
    {
      "id": "vad_stage",
      "name": "VAD Detection Stage",
      "depends_on": ["source_stage"],
      "max_concurrency": 4,
      "input": {
        "key": "audio_frames",
        "chunk_size": 1600
      },
      "ops": [
        {
          "id": "silero_vad",
          "name": "SileroVad",
          "params": {
            "model_path": "${vad_model}",
            "threshold": 0.5,
            "sample_rate": 16000,
            "input_frame_key": "audio_frames",
            "min_speech_duration_ms": 250,
            "min_silence_duration_ms": 100
          }
        }
      ]
    }
  ]
}
